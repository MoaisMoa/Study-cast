<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.younghee.studycast.dao.UserSubscriptionMapper">

    <resultMap id="UserSubscriptionResultMap" type="com.younghee.studycast.dto.UserSubscriptionDTO">
        <id     property="subscriptionId" column="subscription_id"/>
        <result property="userUuid"       column="user_uuid"/>
        <result property="plan"           column="plan"/>
        <result property="billingKey"     column="billing_key"/>
        <result property="customerKey"    column="customer_key"/>
        <result property="status"         column="status"/>
        <result property="startedAt"      column="started_at"/>
        <result property="nextBillingAt"  column="next_billing_at"/>
        <result property="cancelledAt"    column="cancelled_at"/>
        <result property="createdAt"      column="created_at"/>
        <result property="updatedAt"      column="updated_at"/>
    </resultMap>

    <insert id="insertSubscription"
            parameterType="com.younghee.studycast.dto.UserSubscriptionDTO"
            useGeneratedKeys="true"
            keyProperty="subscriptionId"
            keyColumn="subscription_id">
        INSERT INTO user_subscriptions
            (user_uuid, plan, billing_key, customer_key, status, started_at, next_billing_at)
        VALUES
            (#{userUuid}, #{plan}, #{billingKey}, #{customerKey}, #{status}, #{startedAt}, #{nextBillingAt})
    </insert>

    <select id="findActiveByUserUuid" resultMap="UserSubscriptionResultMap">
        SELECT * FROM user_subscriptions
        WHERE user_uuid = #{userUuid}
          AND status = 'ACTIVE'
        LIMIT 1
    </select>

    <update id="updateStatus">
        UPDATE user_subscriptions
        SET status       = #{status},
            cancelled_at = #{cancelledAt},
            updated_at   = NOW()
        WHERE subscription_id = #{subscriptionId}
    </update>

    <update id="updateNextBillingAt">
        UPDATE user_subscriptions
        SET next_billing_at = #{nextBillingAt},
            updated_at      = NOW()
        WHERE subscription_id = #{subscriptionId}
    </update>

    <select id="findDueBillings" resultMap="UserSubscriptionResultMap">
        SELECT * FROM user_subscriptions
        WHERE status = 'ACTIVE'
          AND next_billing_at &lt;= NOW()
    </select>

</mapper>
