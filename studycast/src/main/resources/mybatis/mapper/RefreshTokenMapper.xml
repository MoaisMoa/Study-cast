<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.younghee.dao.RefreshTokenMapper">

    <resultMap id="RefreshTokenResultMap" type="com.younghee.dto.RefreshTokenDTO">
        <id property="tokenNo" column="token_no"/>
        <result property="userUuid" column="user_uuid"/>
        <result property="tokenHash" column="token_hash"/>
        <result property="expiryDate" column="expiry_date"/>
        <result property="revoked" column="revoked"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- Refresh Token 저장 -->
    <insert id="insert" parameterType="RefreshTokenDTO">
        INSERT INTO refresh_tokens (
            user_uuid,
            token_hash,
            expiry_date,
            revoked
        )
        VALUES (
            #{userUuid},
            #{tokenHash},
            #{expiryDate},
            #{revoked}
        )
    </insert>

    <!-- token_hash로 Refresh Token 조회 -->
    <select id="findByTokenHash" resultMap="RefreshTokenResultMap">
        SELECT 
            token_no,
            user_uuid,
            token_hash,
            expiry_date,
            revoked,
            created_at
        FROM refresh_tokens
        WHERE token_hash = #{tokenHash}
    </select>

    <!-- 로그아웃 시 Refresh Token 폐기 -->
    <update id="revokeByTokenHash">
        UPDATE refresh_tokens
        SET revoked = TRUE
        WHERE token_hash = #{tokenHash}
    </update>

    <!-- 해당 사용자의 모든 Refresh Token 폐기 -->
    <update id="revokeAllByUserUuid">
        UPDATE refresh_tokens
        SET revoked = TRUE
        WHERE user_uuid = #{userUuid}
    </update>
</mapper>