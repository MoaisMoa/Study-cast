<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.younghee.studycast.dao.DdayMapper">

    <resultMap id="DdayResultMap" type="com.younghee.studycast.dto.DdaysDTO">
        <id   property="ddayNo"     column="dday_no"/>
        <result property="userUuid"   column="user_uuid"/>
        <result property="ddayTitle"  column="dday_title"/>
        <result property="targetDate" column="target_date"/>
        <result property="main"       column="is_main"/>
        <result property="createdAt"  column="created_at"/>
        <result property="updatedAt"  column="updated_at"/>
    </resultMap>

    <select id="findAllByUser" resultMap="DdayResultMap">
        SELECT dday_no, user_uuid, dday_title,
               target_date, is_main, created_at, updated_at
        FROM ddays
        WHERE user_uuid = #{userUuid}
        ORDER BY target_date ASC, created_at ASC
    </select>

    <!-- 디데이 등록 -->
    <insert id="insert">
        INSERT INTO ddays (user_uuid, dday_title, target_date)
        VALUES (#{userUuid}, #{ddayTitle}, #{targetDate})
    </insert>

    <!-- 디데이 삭제 (본인 소유 확인) -->
    <delete id="deleteByIdAndUser">
        DELETE FROM ddays
        WHERE dday_no = #{ddayNo}
          AND user_uuid = #{userUuid}
    </delete>

</mapper>
