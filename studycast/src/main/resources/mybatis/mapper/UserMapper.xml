<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.younghee.studycast.dao.UserMapper">
    <resultMap id="UserResultMap" type="com.younghee.studycast.dto.UserDTO">
        <id property="userUuid" column="user_uuid"/>
        <result property="userEmail" column="user_email"/>
        <result property="userPassword" column="user_password"/>
        <result property="userName" column="user_name"/>
        <result property="userProfileImage" column="user_profile_image"/>
        <result property="userStatus" column="user_status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deletedAt" column="deleted_at"/>
    </resultMap>

    <!-- 이메일로 회원 조회 -->
    <select id="findByEmail" resultMap="UserResultMap">
        SELECT
            user_uuid,
            user_email,
            user_password,
            user_name,
            user_profile_image,
            user_status,
            created_at,
            updated_at,
            deleted_at
        FROM users
        WHERE user_email = #{userEmail}
    </select>

    <!-- UUID로 회원 조회 -->
    <select id="findByUuid" resultMap="UserResultMap">
        SELECT
            user_uuid,
            user_email,
            user_password,
            user_name,
            user_profile_image,
            user_status,
            created_at,
            updated_at,
            deleted_at
        FROM users
        WHERE user_uuid = #{userUuid}
    </select>

    <!-- 회원가입 -->
    <insert id="insertUser" parameterType="UserDTO">
        INSERT INTO users (
            user_uuid,
            user_email,
            user_password,
            user_name,
            user_profile_image,
            user_status
        ) 
        VALUES (
            #{userUuid},
            #{userEmail},
            #{userPassword},
            #{userName},
            #{userProfileImage},
            COALESCE(#{userStatus}, 'ACTIVE')
        )
    </insert>

    <!-- 사용자 상태 변경 -->
    <update id="updatedUserStatus">
        UPDATE users
        SET
            user_status = #{userStatus},
            updated_at = CURRENT_TIMESTAMP
        WHERE user_uuid = #{userUuid}
    </update>
</mapper>