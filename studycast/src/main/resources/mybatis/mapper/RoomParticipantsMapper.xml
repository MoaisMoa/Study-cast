<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.younghee.studycast.dao.RoomParticipantsMapper">

    <resultMap id="RoomParticipantResultMap" type="com.younghee.studycast.dto.RoomParticipantDTO">
        <id property="partNo" column="part_no"/>
        <result property="userUuid" column="user_uuid"/>
        <result property="roomNo" column="room_no"/>
        <result property="cameraStatus" column="camera_status"/>
        <result property="micStatus" column="mic_status"/>
    </resultMap>

    <!-- 방 참여자 등록 -->
    <insert id="insertRoomParticipant"
            parameterType="RoomParticipantDTO"
            useGeneratedKeys="true"
            keyProperty="partNo"
            keyColumn="part_no">
        INSERT INTO room_participants (
            user_uuid, room_no, camera_status, mic_status
        ) VALUES (
            #{userUuid}, #{roomNo}, #{cameraStatus}, #{micStatus}
        )
    </insert>

    <!-- 방 번호 + 사용자 UUID로 참여자 조회 -->
    <select id="findByRoomNoAndUserUuid"
            parameterType="RoomParticipantDTO"
            resultMap="RoomParticipantResultMap">
        SELECT *
        FROM room_participants
        WHERE room_no = #{roomNo}
            AND user_uuid=#{userUuid}
    </select>
</mapper>