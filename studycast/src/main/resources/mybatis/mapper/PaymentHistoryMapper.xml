<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.younghee.studycast.dao.PaymentHistoryMapper">

    <resultMap id="PaymentHistoryResultMap" type="com.younghee.studycast.dto.PaymentHistoryDTO">
        <id     property="paymentId"      column="payment_id"/>
        <result property="userUuid"       column="user_uuid"/>
        <result property="subscriptionId" column="subscription_id"/>
        <result property="orderId"        column="order_id"/>
        <result property="paymentKey"     column="payment_key"/>
        <result property="amount"         column="amount"/>
        <result property="plan"           column="plan"/>
        <result property="status"         column="status"/>
        <result property="paidAt"         column="paid_at"/>
        <result property="failedReason"   column="failed_reason"/>
        <result property="createdAt"      column="created_at"/>
    </resultMap>

    <insert id="insertPaymentHistory"
            parameterType="com.younghee.studycast.dto.PaymentHistoryDTO"
            useGeneratedKeys="true"
            keyProperty="paymentId"
            keyColumn="payment_id">
        INSERT INTO payment_history
            (user_uuid, subscription_id, order_id, payment_key, amount, plan, status, paid_at, failed_reason)
        VALUES
            (#{userUuid}, #{subscriptionId}, #{orderId}, #{paymentKey}, #{amount}, #{plan}, #{status}, #{paidAt}, #{failedReason})
    </insert>

    <select id="findByUserUuid" resultMap="PaymentHistoryResultMap">
        SELECT * FROM payment_history
        WHERE user_uuid = #{userUuid}
        ORDER BY created_at DESC
        LIMIT 20
    </select>

</mapper>
