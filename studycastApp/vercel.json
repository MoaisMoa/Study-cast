{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://api.studycast.co.kr/api/:path*" },
    { "source": "/room-images/:path*", "destination": "https://api.studycast.co.kr/room-images/:path*" },
    { "source": "/oauth2/:path*", "destination": "https://api.studycast.co.kr/oauth2/:path*" },
    { "source": "/login/oauth2/:path*", "destination": "https://api.studycast.co.kr/login/oauth2/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
